# 复制为 .env 并填好（Node / VPS / Docker 部署用；Workers 用 wrangler secret）。

# 【必填】手机与本后端之间的共享密钥。随便生成一个长随机串，
#         同一个值要填到 APP 设置页的「中继密钥」里。两端一致才放行。
#   生成示例：openssl rand -hex 32
RELAY_SECRET=

# 端口（默认 8787）
PORT=8787

# outbox 存储：memory（默认，重启清空）/ sqlite（持久，需 better-sqlite3）
RELAY_STORE=memory
# RELAY_SQLITE_PATH=./outbox.db

# 【可选】Web Push (VAPID)。不填则不发推送，手机靠轮询拉取（最通用，大陆也能用）。
#   只用 web-push 这个 npm 包来「生成密钥」，运行时不依赖它（推送是纯 Web Crypto 实现，Workers/Node 通用）：
#     npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# 【可选】iOS APNs 推送（App 完全关闭也能弹通知）。
#   iOS 推送凭据(.p8)绑定 App 开发者账号，普通用户拿不到 → 不在这里持 .p8，
#   而是转发到作者运营的「中心 APNs 中转」(nuojiji-apns-relay)代发。
#   两个都填才发 iOS 推送；不填则 iOS 靠手机轮询兜底。
APNS_RELAY_URL=
APNS_RELAY_SECRET=

# 【可选】OpenAI-compatible Agent Relay（/v1/chat/completions）。
# App 主 API 可填：
#   Base URL: https://你的-worker域名/v1
#   API Key:  同 RELAY_SECRET
# Relay 会先用 Gemini 原生工具调用访问 Ombre MCP，再把 relevant info 交给最终 Claude 代理。
AGENT_COORDINATOR_API_KEY=
AGENT_COORDINATOR_MODEL=gemini-3.5-flash
AGENT_COORDINATOR_BASE_URL=https://gateway.btombre.men/v1beta
AGENT_MAX_TOOL_ROUNDS=8

AGENT_MCP_URL=https://brain.example.com/mcp
# AGENT_MCP_BEARER_TOKEN=
# AGENT_MCP_HEADER_NAME=
# AGENT_MCP_HEADER_VALUE=

AGENT_FINAL_API_URL=https://gateway.btombre.men/v1
AGENT_FINAL_API_KEY=
AGENT_FINAL_MODEL=claude-opus-4-8
AGENT_FINAL_API_TYPE=openai
AGENT_FINAL_OMBRE_SESSION_ID=main

# 【调试】默认关闭。开启后 /debug/agent 会记录完整 prompt/tool 上下文片段，适合短期排查。
# AGENT_DEBUG_FULL_PROMPT=1
# AGENT_DEBUG_FULL_LIMIT_CHARS=200000
